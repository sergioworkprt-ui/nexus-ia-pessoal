{
  "_comment": "NEXUS Live Runtime Configuration — production settings.",
  "mode": "live",
  "log_level": "info",
  "audit_log_path": "logs/live/audit_live.jsonl",
  "intelligence": {
    "mode": "enabled",
    "interval_seconds": 3600,
    "max_urls": 10,
    "sentiment_threshold": 0.3,
    "enabled_patterns": [
      "breakout",
      "breakdown",
      "anomaly_price",
      "anomaly_volume",
      "bullish_divergence",
      "bearish_divergence"
    ]
  },
  "financial": {
    "mode": "enabled",
    "interval_seconds": 1800,
    "max_drawdown_alert": 0.10,
    "sharpe_alert": 0.5,
    "backtest_on_start": false
  },
  "evolution": {
    "mode": "dry_run",
    "interval_seconds": 86400,
    "max_patches_per_cycle": 5,
    "auto_apply_patches": false,
    "scan_paths": [
      "core",
      "auto_evolution",
      "profit_engine",
      "web_intelligence",
      "multi_ia",
      "reports",
      "nexus_runtime"
    ]
  },
  "consensus": {
    "mode": "enabled",
    "interval_seconds": 7200,
    "n_agents": 3,
    "agreement_alert": 0.40,
    "escalate_on_contradiction": true
  },
  "reporting": {
    "mode": "enabled",
    "interval_seconds": 3600,
    "auto_export_json": true,
    "export_dir": "reports/live",
    "report_types": [
      "financial",
      "intelligence",
      "evolution",
      "multi_ia"
    ]
  },
  "scheduler": {
    "enabled": true,
    "tick_interval_s": 1.0,
    "max_concurrent": 4
  },
  "state": {
    "checkpoint_path": "data/runtime/live_checkpoint.json",
    "checkpoint_interval_s": 300,
    "max_checkpoints": 5
  },
  "ibkr": {
    "mode": "paper",
    "enabled": false,
    "initial_capital": 0.0,
    "user_capital_limit": 0.0,
    "recovery_enabled": true,
    "tools_fund_pct": 0.30,
    "reinvest_fund_pct": 0.50,
    "standby_fund_pct": 0.20,
    "max_risk_per_trade": 0.005,
    "max_daily_risk": 0.010,
    "max_weekly_risk": 0.020,
    "max_drawdown": 0.050,
    "cpg_base_url": "https://localhost:5000",
    "cpg_verify_ssl": false,
    "cpg_timeout_s": 10,
    "cpg_account_id": "",
    "host": "127.0.0.1",
    "port": 7497,
    "client_id": 1
  }
}
