[flake8]
max-line-length = 120
extend-ignore = E501, E203, W503, W504
exclude =
    nexus/dashboard/frontend,
    nexus/dashboard/frontend/node_modules,
    .git,
    __pycache__,
    *.egg-info,
    .venv,
    venv,
    nexus/docker
per-file-ignores =
    # Ficheiros gerados ou com linhas longas aceitáveis
    nexus/api/rest/automation.py: E501
    nexus/api/rest/prometheus_metrics.py: E501
    nexus/api/rest/main.py: E501
    nexus/services/logger/structured.py: E501
