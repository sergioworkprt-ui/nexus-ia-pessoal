# === NEXUS Environment Configuration ===
# Copy to .env and fill in your values.
# Paths must be ABSOLUTE when running via systemd.

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# API auth — used as Bearer token
NEXUS_API_KEY=nexus-change-me
NEXUS_SECRET_KEY=nexus-change-me

# Listen address
HOST=0.0.0.0
PORT=8000

# TTS / Voice (set to false to skip heavy audio deps)
TTS_ENGINE=gtts
TTS_ENABLED=false
STT_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Trading
TRADING_BROKER=simulation
TRADING_CONFIRM_CODE=NEXUS-REAL-CONFIRM
IBKR_HOST=127.0.0.1
IBKR_PAPER=true
RISK_MAX_ORDER=10
RISK_MAX_LOSS=500
RISK_MAX_GAIN=2000

# Logging — MUST be an absolute path for systemd
LOG_DIR=/var/log/nexus
LOG_LEVEL=INFO

# Dashboard
NEXUS_API_URL=http://localhost:8000
NEXUS_LOG_DIR=/var/log/nexus
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=9000
