# === NEXUS v2 — Environment Configuration ===

# API auth
NEXUS_API_KEY=nexus-change-me
NEXUS_SECRET_KEY=nexus-change-me-use-32-random-chars
NEXUS_PIN_HASH=   # sha256 of your PIN (leave empty to set via /security/pin/verify)

# Listen
HOST=0.0.0.0
PORT=8000

# LLM (OpenAI-compatible)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Multi-AI learning (optional)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# TTS / Voice
TTS_ENGINE=gtts
TTS_ENABLED=false
STT_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Trading
TRADING_BROKER=simulation
TRADING_CONFIRM_CODE=NEXUS-REAL-CONFIRM
RISK_MAX_ORDER=10
RISK_MAX_LOSS=500
RISK_MAX_GAIN=2000

# XTB
XTB_ACCOUNT_ID=
XTB_PASSWORD=
XTB_SERVER=demo

# IBKR
IBKR_HOST=127.0.0.1
IBKR_PORT=5000
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
IBKR_PAPER=true

# Truth Checker
SERP_API_KEY=

# Logging — MUST be absolute path
LOG_DIR=/var/log/nexus
LOG_LEVEL=INFO

# Dashboard
NEXUS_API_URL=http://localhost:8000
NEXUS_LOG_DIR=/var/log/nexus
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=9000
