# Stage 1: build React
FROM node:20-alpine AS builder
WORKDIR /app
COPY nexus/dashboard/frontend/package.json nexus/dashboard/frontend/package-lock.json* ./
RUN npm ci
COPY nexus/dashboard/frontend/ .
RUN npm run build

# Stage 2: serve with nginx
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nexus/docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
